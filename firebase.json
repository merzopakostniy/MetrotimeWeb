{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".obsidian/**",
      "📋 Проект/**",
      "🏗️ Архитектура/**",
      "🎨 Дизайн/**",
      "💡 Идеи/**",
      "💳 Монетизация/**",
      "🐛 Баги/**",
      "*.canvas",
      "*.md",
      "assets/*.imageset/**",
      "node_modules/**"
    ],
    "headers": [
      {
        "source": "sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
